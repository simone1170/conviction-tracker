# SEC EDGAR (required)
# Format: "FirstName LastName email@example.com"
SEC_USER_AGENT=Your Name your.email@example.com

# Congressional API (optional — leave blank to disable module)
# Supported providers: quiverquant | capitoltrades | finnhub | fmp
CONGRESS_API_PROVIDER=
CONGRESS_API_KEY=

# ETF data (required for Middle Ring sector mapping)
ETF_API_PROVIDER=fmp
ETF_API_KEY=your_fmp_api_key_here

# Telegram (required)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Scheduling
CRON_SCHEDULE=0 18 * * 1-5
HEARTBEAT_TIME=07:00

# Alert tuning
DAILY_ALERT_DIGEST_THRESHOLD=5
DIGEST_SEND_TIME=20:00

# Congressional confirmation lookback (only used if module is enabled)
CONFIRMATION_LOOKBACK_DAYS=30

# Logging
LOG_LEVEL=INFO

# Database
DB_PATH=data/conviction.db
